generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String        @unique
  password     String
  role         Role          @default(USER)
  isActive     Boolean       @default(true)
  shopName     String
  languagePref String?       @default("en")
  transactions Transaction[]
  DailySummary DailySummary[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Transaction {
  id           String          @id @default(uuid())
  amount       Float
  description  String
  type         TransactionType
  category     String?
  customerName String?
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id])
  userId       Int

  @@map("transactions")
}

enum TransactionType {
  SALE
  EXPENSE
  CREDIT_GIVEN
  CREDIT_RECEIVED
}

model DailySummary {
  id               String   @id @default(uuid())
  date             DateTime @default(now())
  totalSales       Float
  totalExpenses    Float
  netProfit        Float
  pendingUdhaar    Float
  transactionCount Int
  user             User     @relation(fields: [userId], references: [id])
  userId           Int

  @@map("daily_summaries")
}
