# Copy values into your environment or IDE run configuration (Spring Boot does not load .env by default).

# Profile: omit or set to postgres for Neon/Postgres; default in application.properties is local (H2 in-memory).
# SPRING_PROFILES_ACTIVE=postgres

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/dukaan
SPRING_DATASOURCE_USERNAME=dukaan
SPRING_DATASOURCE_PASSWORD=

# Min 32 bytes recommended if using raw text; plain strings are hashed automatically in code.
JWT_SECRET=change-me-to-a-long-random-secret-for-local-dev-only

GROQ_API_KEY=
